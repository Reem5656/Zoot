<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Zoot – זכויות לכולם</title>
  <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700;900&display=swap" rel="stylesheet"/>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --blue: #1a56db;
      --blue-light: #e8f0fe;
      --blue-dark: #0f3a8a;
      --white: #ffffff;
      --gray: #f4f6fb;
      --gray2: #e2e8f0;
      --text: #1a202c;
      --text-soft: #64748b;
      --green: #10b981;
      --orange: #f59e0b;
      --red: #ef4444;
      --purple: #8b5cf6;
    }

    body {
      font-family: 'Heebo', sans-serif;
      background: var(--gray);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: flex-start;
    }

    .phone {
      width: 100%;
      max-width: 430px;
      min-height: 100vh;
      background: var(--white);
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    /* ========== STATUS BAR ========== */
    .status-bar {
      background: var(--blue-dark);
      color: white;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 6px 16px;
      font-size: 12px;
      font-weight: 500;
    }

    /* ========== SCREENS ========== */
    .screen { display: none; flex-direction: column; flex: 1; }
    .screen.active { display: flex; }

    /* ========== HOME SCREEN ========== */
    .home-header {
      background: linear-gradient(135deg, var(--blue-dark) 0%, var(--blue) 100%);
      padding: 20px 20px 32px;
      color: white;
      position: relative;
      overflow: hidden;
    }
    .home-header::before {
      content: '';
      position: absolute;
      top: -30px; left: -30px;
      width: 180px; height: 180px;
      background: rgba(255,255,255,0.05);
      border-radius: 50%;
    }
    .home-header::after {
      content: '';
      position: absolute;
      bottom: -40px; right: -20px;
      width: 140px; height: 140px;
      background: rgba(255,255,255,0.06);
      border-radius: 50%;
    }
    .home-header .logo {
      font-size: 28px;
      font-weight: 900;
      letter-spacing: -1px;
      position: relative;
      z-index: 1;
    }
    .home-header .logo span { color: #93c5fd; }
    .home-header .tagline {
      font-size: 14px;
      opacity: 0.85;
      margin-top: 4px;
      position: relative;
      z-index: 1;
    }
    .search-box {
      background: white;
      border-radius: 14px;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 18px;
      position: relative;
      z-index: 1;
      box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    }
    .search-box input {
      border: none;
      outline: none;
      flex: 1;
      font-family: 'Heebo', sans-serif;
      font-size: 15px;
      color: var(--text);
      background: transparent;
    }
    .search-box input::placeholder { color: var(--text-soft); }
    .search-icon { color: var(--text-soft); font-size: 18px; }

    .quiz-banner {
      margin: 16px;
      background: linear-gradient(135deg, #1e40af, #3b82f6);
      border-radius: 16px;
      padding: 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 16px rgba(26,86,219,0.3);
    }
    .quiz-banner:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(26,86,219,0.4); }
    .quiz-banner:active { transform: scale(0.98); }
    .quiz-banner-text .title { color: white; font-weight: 700; font-size: 16px; }
    .quiz-banner-text .sub { color: rgba(255,255,255,0.8); font-size: 13px; margin-top: 4px; }
    .quiz-banner-arrow {
      background: rgba(255,255,255,0.2);
      width: 42px; height: 42px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 20px;
      flex-shrink: 0;
    }

    .section-title {
      font-size: 16px;
      font-weight: 700;
      color: var(--text);
      padding: 0 16px;
      margin-bottom: 12px;
    }

    .topics-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      padding: 0 16px;
      margin-bottom: 16px;
    }
    .topic-card {
      background: var(--white);
      border-radius: 16px;
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
      border: 1.5px solid var(--gray2);
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .topic-card:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.1); }
    .topic-card:active { transform: scale(0.97); }
    .topic-icon {
      width: 44px; height: 44px;
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 22px;
    }
    .topic-card h3 { font-size: 14px; font-weight: 700; color: var(--text); }
    .topic-card p { font-size: 12px; color: var(--text-soft); line-height: 1.4; }

    .home-content { overflow-y: auto; padding-bottom: 80px; padding-top: 16px; }

    /* ========== BOTTOM NAV ========== */
    .bottom-nav {
      position: fixed;
      bottom: 0;
      width: 100%;
      max-width: 430px;
      background: var(--white);
      border-top: 1px solid var(--gray2);
      display: flex;
      justify-content: space-around;
      padding: 8px 0 14px;
      z-index: 100;
      box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
    }
    .nav-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      cursor: pointer;
      color: var(--text-soft);
      font-size: 11px;
      font-weight: 500;
      transition: color 0.2s;
      padding: 4px 16px;
    }
    .nav-item.active { color: var(--blue); }
    .nav-item .nav-icon { font-size: 22px; }

    /* ========== QUIZ SCREEN ========== */
    .quiz-header {
      background: linear-gradient(135deg, var(--blue-dark), var(--blue));
      padding: 20px 20px 24px;
      color: white;
    }
    .quiz-header .top-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }
    .back-btn {
      background: rgba(255,255,255,0.15);
      border: none;
      color: white;
      width: 36px; height: 36px;
      border-radius: 50%;
      font-size: 18px;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s;
    }
    .back-btn:hover { background: rgba(255,255,255,0.25); }
    .quiz-step-label { font-size: 13px; opacity: 0.8; }
    .progress-bar-wrap {
      background: rgba(255,255,255,0.25);
      border-radius: 99px;
      height: 6px;
      overflow: hidden;
    }
    .progress-bar-fill {
      background: white;
      height: 100%;
      border-radius: 99px;
      transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .quiz-question {
      font-size: 20px;
      font-weight: 700;
      margin-top: 14px;
      line-height: 1.4;
    }
    .quiz-sub {
      font-size: 13px;
      opacity: 0.8;
      margin-top: 6px;
    }

    .quiz-body { padding: 20px 16px; overflow-y: auto; padding-bottom: 100px; }

    .options-grid { display: flex; flex-direction: column; gap: 10px; }
    .options-grid.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

    .option-btn {
      background: var(--white);
      border: 2px solid var(--gray2);
      border-radius: 14px;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      cursor: pointer;
      transition: all 0.2s;
      text-align: right;
      font-family: 'Heebo', sans-serif;
    }
    .option-btn:hover { border-color: var(--blue); background: var(--blue-light); }
    .option-btn.selected {
      border-color: var(--blue);
      background: var(--blue-light);
      box-shadow: 0 0 0 3px rgba(26,86,219,0.12);
    }
    .option-btn .opt-icon {
      font-size: 24px;
      flex-shrink: 0;
    }
    .option-btn .opt-text { font-size: 14px; font-weight: 600; color: var(--text); flex: 1; }
    .option-btn .opt-desc { font-size: 12px; color: var(--text-soft); margin-top: 2px; }
    .option-btn.two-col-item {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 18px 12px;
    }

    .name-input-wrap {
      position: relative;
    }
    .name-input {
      width: 100%;
      border: 2px solid var(--gray2);
      border-radius: 14px;
      padding: 16px 18px;
      font-family: 'Heebo', sans-serif;
      font-size: 18px;
      color: var(--text);
      outline: none;
      transition: border-color 0.2s;
      background: white;
    }
    .name-input:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(26,86,219,0.1); }

    .interests-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .interest-btn {
      background: white;
      border: 2px solid var(--gray2);
      border-radius: 14px;
      padding: 14px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      transition: all 0.2s;
      font-family: 'Heebo', sans-serif;
    }
    .interest-btn:hover { border-color: var(--blue); background: var(--blue-light); }
    .interest-btn.selected {
      border-color: var(--blue);
      background: var(--blue-light);
      box-shadow: 0 0 0 3px rgba(26,86,219,0.12);
    }
    .interest-btn .i-icon { font-size: 28px; }
    .interest-btn .i-text { font-size: 13px; font-weight: 600; color: var(--text); }

    .next-btn {
      width: 100%;
      background: linear-gradient(135deg, var(--blue-dark), var(--blue));
      color: white;
      border: none;
      border-radius: 14px;
      padding: 16px;
      font-family: 'Heebo', sans-serif;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      margin-top: 20px;
      transition: all 0.2s;
      box-shadow: 0 4px 16px rgba(26,86,219,0.3);
    }
    .next-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(26,86,219,0.4); }
    .next-btn:active { transform: scale(0.98); }
    .next-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    /* ========== RESULTS SCREEN ========== */
    .results-header {
      background: linear-gradient(135deg, var(--blue-dark), var(--blue));
      padding: 30px 20px;
      color: white;
      text-align: center;
    }
    .results-emoji { font-size: 56px; margin-bottom: 12px; }
    .results-title { font-size: 24px; font-weight: 900; }
    .results-subtitle { font-size: 14px; opacity: 0.85; margin-top: 6px; }

    .results-body { padding: 20px 16px; overflow-y: auto; padding-bottom: 100px; }

    .result-card {
      background: white;
      border-radius: 16px;
      padding: 16px;
      margin-bottom: 12px;
      border: 1.5px solid var(--gray2);
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
      display: flex;
      gap: 14px;
      align-items: flex-start;
    }
    .result-card-icon {
      width: 46px; height: 46px;
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 22px;
      flex-shrink: 0;
    }
    .result-card-text h3 { font-size: 15px; font-weight: 700; color: var(--text); }
    .result-card-text p { font-size: 13px; color: var(--text-soft); margin-top: 4px; line-height: 1.5; }
    .result-badge {
      display: inline-block;
      background: var(--blue-light);
      color: var(--blue);
      font-size: 11px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 99px;
      margin-top: 8px;
    }

    .restart-btn {
      width: 100%;
      background: white;
      color: var(--blue);
      border: 2px solid var(--blue);
      border-radius: 14px;
      padding: 14px;
      font-family: 'Heebo', sans-serif;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      margin-top: 8px;
      transition: all 0.2s;
    }
    .restart-btn:hover { background: var(--blue-light); }

    /* ========== ABOUT / PROFILE SCREEN ========== */
    .about-header {
      background: linear-gradient(135deg, var(--blue-dark), var(--blue));
      padding: 30px 20px;
      color: white;
      text-align: center;
    }
    .about-avatar {
      width: 80px; height: 80px;
      background: rgba(255,255,255,0.2);
      border-radius: 50%;
      margin: 0 auto 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 40px;
    }
    .about-name { font-size: 22px; font-weight: 800; }
    .about-sub { font-size: 13px; opacity: 0.8; margin-top: 4px; }

    .about-body { padding: 20px 16px; }
    .about-section {
      background: white;
      border-radius: 16px;
      border: 1.5px solid var(--gray2);
      overflow: hidden;
      margin-bottom: 16px;
    }
    .about-row {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 16px;
      border-bottom: 1px solid var(--gray2);
      cursor: pointer;
      transition: background 0.15s;
    }
    .about-row:last-child { border-bottom: none; }
    .about-row:hover { background: var(--gray); }
    .about-row-icon { font-size: 22px; width: 32px; text-align: center; }
    .about-row-text { flex: 1; }
    .about-row-text .row-title { font-size: 14px; font-weight: 600; color: var(--text); }
    .about-row-text .row-sub { font-size: 12px; color: var(--text-soft); margin-top: 2px; }
    .about-row-arrow { color: var(--text-soft); font-size: 16px; }

    /* Animations */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .screen.active { animation: fadeInUp 0.3s ease; }
  </style>
</head>
<body>
<div class="phone">
  <div class="status-bar">
    <span>9:41</span>
    <span>⚡ Zoot</span>
    <span>📶 🔋</span>
  </div>

  <!-- ===== HOME SCREEN ===== -->
  <div class="screen active" id="screen-home">
