        <span class="nav-icon">🎯</span>
        <span>שאלון</span>
      </div>
      <div class="nav-item" onclick="showScreen('about')">
        <span class="nav-icon">👤</span>
        <span>פרופיל</span>
      </div>
    </div>
  </div>

  <!-- ===== QUIZ SCREEN ===== -->
  <div class="screen" id="screen-quiz">
