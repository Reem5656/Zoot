      </div>
      <div class="nav-item" onclick="showScreen('quiz-start')">
        <span class="nav-icon">🎯</span><span>שאלון</span>
      </div>
      <div class="nav-item active">
        <span class="nav-icon">👤</span><span>פרופיל</span>
      </div>
    </div>
  </div>

</div>

<script>
  // ===== DATA =====
  const questions = [
    {
      id: 'name',
      question: 'איך קוראים לך?',
      sub: 'נשתמש בשמך כדי לפנות אליך',
      type: 'text',
      placeholder: 'הכנס את שמך...'
    },
    {
      id: 'who',
      question: 'מי אתה?',
      sub: 'בחר את המצב הקרוב אליך',
      type: 'single',
      options: [
        { icon: '💼', text: 'עובד שכיר', desc: 'מועסק אצל מעסיק' },
        { icon: '🏢', text: 'עצמאי', desc: 'עסק עצמאי' },
        { icon: '📚', text: 'סטודנט', desc: 'לומד באקדמיה' },
        { icon: '🔍', text: 'מחפש עבודה', desc: 'לא מועסק כרגע' },
        { icon: '👶', text: 'הורה', desc: 'עם ילדים קטנים' },
        { icon: '👴', text: 'קשיש', desc: 'מעל גיל 65' }
      ]
    },
    {
      id: 'age',
      question: 'באיזה טווח גיל אתה?',
      sub: 'הגיל עשוי להשפיע על הזכויות שלך',
      type: 'single',
      twoCol: true,
      options: [
        { icon: '🧒', text: 'מתחת ל-25' },
        { icon: '🧑', text: '25–40' },
        { icon: '🧔', text: '40–60' },
        { icon: '👴', text: 'מעל 60' }
      ]
    },
    {
      id: 'location',
      question: 'איפה אתה גר?',
      sub: 'חלק מהזכויות משתנות לפי מיקום',
      type: 'single',
      options: [
        { icon: '🏙️', text: 'מרכז', desc: 'תל אביב, גוש דן' },
        { icon: '🏔️', text: 'צפון', desc: 'חיפה והצפון' },
        { icon: '🌅', text: 'דרום', desc: 'באר שבע והנגב' },
        { icon: '🕌', text: 'ירושלים', desc: 'ירושלים והסביבה' }
      ]
    },
    {
      id: 'interests',
      question: 'אילו נושאים מעניינים אותך?',
      sub: 'ניתן לבחור מספר תחומים',
      type: 'multi',
      options: [
        { icon: '💼', text: 'תעסוקה' },
        { icon: '🏥', text: 'בריאות' },
        { icon: '👪', text: 'משפחה' },
        { icon: '🎓', text: 'חינוך' },
        { icon: '🏠', text: 'דיור' },
        { icon: '💰', text: 'כספים' }
      ]
    }
  ];

  const rightsDB = {
    עובד_שכיר: [
      { icon: '💰', color: '#fef3c7', title: 'פיצויי פיטורים', desc: 'זכאי לפיצויי פיטורים לאחר שנת עבודה', badge: 'זכאי' },
      { icon: '🏖️', color: '#e0f2fe', title: 'ימי חופשה', desc: '16 ימי חופשה בשנה לפחות', badge: 'זכאי' },
      { icon: '🤒', color: '#f0fdf4', title: 'ימי מחלה', desc: '18 ימי מחלה צבורים בשנה', badge: 'זכאי' }
    ],
    עצמאי: [
      { icon: '📋', color: '#fdf4ff', title: 'ביטוח לאומי מופחת', desc: 'תשלומי ביטוח לאומי מותאמים לעצמאים', badge: 'לבדוק' },
      { icon: '💳', text: 'הטבות מס', color: '#fef9c3', title: 'הטבות מס לעצמאים', desc: 'ניכויים מיוחדים על הוצאות עסקיות', badge: 'זכאי' }
    ],
    סטודנט: [
      { icon: '🎓', color: '#e0f2fe', title: 'מלגת נצרכות', desc: 'סיוע כלכלי לסטודנטים זכאים', badge: 'זכאי' },
      { icon: '🚌', color: '#f0fdf4', title: 'הנחה בתחבורה', desc: '33% הנחה בתחבורה ציבורית', badge: 'זכאי' },
      { icon: '🏠', color: '#fdf4ff', title: 'מעונות סטודנטים', desc: 'דיור מסובסד במוסדות לימוד', badge: 'לבדוק' }
    ],
    מחפש_עבודה: [
      { icon: '💵', color: '#fef3c7', title: 'דמי אבטלה', desc: 'עד 80% מהשכר הקודם למשך 138 ימים', badge: 'זכאי' },
      { icon: '📚', color: '#e0f2fe', title: 'הכשרה מקצועית', desc: 'קורסים מסובסדים דרך שירות התעסוקה', badge: 'זכאי' }
    ],
    הורה: [
      { icon: '👶', color: '#fdf4ff', title: 'קצבת ילדים', desc: 'תשלום חודשי עבור כל ילד מביטוח לאומי', badge: 'זכאי' },
      { icon: '🍼', color: '#f0fdf4', title: 'חופשת לידה', desc: 'עד 26 שבועות חופשת לידה בתשלום', badge: 'זכאי' },
      { icon: '📚', color: '#e0f2fe', title: 'חינוך חינמי', desc: 'חינוך חינמי לילדים מגיל 3', badge: 'זכאי' }
    ],
    קשיש: [
      { icon: '💰', color: '#fef3c7', title: 'קצבת זקנה', desc: 'קצבה חודשית מביטוח לאומי מגיל 67', badge: 'זכאי' },
      { icon: '🚌', color: '#e0f2fe', title: 'תחבורה חינמית', desc: 'נסיעות חינמיות לגמלאים', badge: 'זכאי' },
      { icon: '🏥', color: '#f0fdf4', title: 'השתתפות בתרופות', desc: 'הנחה בתשלום עבור תרופות', badge: 'זכאי' }
    ]
  };

  // ===== STATE =====
  let currentStep = 0;
  let answers = {};
  let multiSelected = [];
  let currentAnswer = null;

  // ===== NAVIGATION =====
  function showScreen(name) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById('screen-' + name).classList.add('active');
  }

  function startQuiz() {
    currentStep = 0;
    answers = {};
    multiSelected = [];
    currentAnswer = null;
    showScreen('quiz');
    renderQuestion();
  }

  function goBack() {
    if (currentStep > 0) {
      currentStep--;
      renderQuestion();
    } else {
      showScreen('home');
    }
  }

  // ===== QUIZ LOGIC =====
  function renderQuestion() {
    const q = questions[currentStep];
    const total = questions.length;
    const pct = ((currentStep + 1) / total) * 100;

    document.getElementById('step-label').textContent = `שאלה ${currentStep + 1} מתוך ${total}`;
    document.getElementById('progress-fill').style.width = pct + '%';
    document.getElementById('quiz-question').textContent = q.question;
    document.getElementById('quiz-sub').textContent = q.sub;

    const body = document.getElementById('quiz-body');
    currentAnswer = answers[q.id] || null;
    multiSelected = answers[q.id] || [];

    if (q.type === 'text') {
      body.innerHTML = `
        <div class="name-input-wrap">
          <input class="name-input" type="text" placeholder="${q.placeholder}" 
            id="name-input" value="${answers[q.id] || ''}" 
            oninput="currentAnswer = this.value; updateNextBtn()"/>
        </div>
        <button class="next-btn" id="next-btn" onclick="nextStep()" ${answers[q.id] ? '' : 'disabled'}>
          המשך ←
        </button>`;
      setTimeout(() => document.getElementById('name-input')?.focus(), 100);
    } else if (q.type === 'single') {
      const grid = q.twoCol ? 'options-grid two-col' : 'options-grid';
      const itemClass = q.twoCol ? 'option-btn two-col-item' : 'option-btn';
      body.innerHTML = `
        <div class="${grid}">
          ${q.options.map(opt => `
            <button class="${itemClass} ${currentAnswer === opt.text ? 'selected' : ''}" 
              onclick="selectSingle(this, '${opt.text}')">
              <span class="opt-icon">${opt.icon}</span>
              <div>
                <div class="opt-text">${opt.text}</div>
                ${opt.desc ? `<div class="opt-desc">${opt.desc}</div>` : ''}
              </div>
            </button>`).join('')}
        </div>
        <button class="next-btn" id="next-btn" onclick="nextStep()" ${currentAnswer ? '' : 'disabled'}>
          המשך ←
        </button>`;
    } else if (q.type === 'multi') {
      body.innerHTML = `
        <div class="interests-grid">
          ${q.options.map(opt => `
            <button class="interest-btn ${multiSelected.includes(opt.text) ? 'selected' : ''}"
              onclick="toggleMulti(this, '${opt.text}')">
              <span class="i-icon">${opt.icon}</span>
              <span class="i-text">${opt.text}</span>
            </button>`).join('')}
        </div>
        <button class="next-btn" id="next-btn" onclick="nextStep()" ${multiSelected.length > 0 ? '' : 'disabled'}>
          סיום וקבלת תוצאות 🎉
        </button>`;
    }
  }

  function selectSingle(btn, val) {
    document.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    currentAnswer = val;
    updateNextBtn();
  }

  function toggleMulti(btn, val) {
    if (multiSelected.includes(val)) {
      multiSelected = multiSelected.filter(v => v !== val);
      btn.classList.remove('selected');
    } else {
      multiSelected.push(val);
      btn.classList.add('selected');
    }
    updateNextBtn();
  }

  function updateNextBtn() {
    const btn = document.getElementById('next-btn');
    if (!btn) return;
    const q = questions[currentStep];
    if (q.type === 'text') btn.disabled = !currentAnswer || currentAnswer.trim() === '';
    else if (q.type === 'single') btn.disabled = !currentAnswer;
    else if (q.type === 'multi') btn.disabled = multiSelected.length === 0;
  }

  function nextStep() {
    const q = questions[currentStep];
    if (q.type === 'text') answers[q.id] = currentAnswer;
    else if (q.type === 'single') answers[q.id] = currentAnswer;
    else if (q.type === 'multi') answers[q.id] = [...multiSelected];

    currentStep++;
    if (currentStep >= questions.length) {
      showResults();
    } else {
      currentAnswer = null;
      multiSelected = [];
      renderQuestion();
    }
  }

  // ===== RESULTS =====
  function showResults() {
    const name = answers['name'] || 'משתמש יקר';
    const who = answers['who'] || '';
    const key = who.replace(' ', '_');

    document.getElementById('results-title').textContent = `${name}, הנה הזכויות שלך! 🎉`;
    document.getElementById('results-subtitle').textContent = `מצאנו ${(rightsDB[key] || []).length + 2} זכויות רלוונטיות עבורך`;
    document.getElementById('profile-name').textContent = `שלום, ${name}!`;

    const rights = rightsDB[key] || rightsDB['עובד_שכיר'];
    const body = document.getElementById('results-body');
    body.innerHTML = rights.map(r => `
      <div class="result-card">
        <div class="result-card-icon" style="background:${r.color}">${r.icon}</div>
        <div class="result-card-text">
          <h3>${r.title}</h3>
          <p>${r.desc}</p>
          <span class="result-badge">${r.badge}</span>
        </div>
      </div>`).join('') +
      `<button class="restart-btn" onclick="startQuiz()">🔄 מלא שאלון מחדש</button>
       <button class="next-btn" style="margin-top:10px" onclick="showScreen('home')">🏠 חזור לדף הבית</button>`;

    showScreen('results');
  }
</script>
</body>
